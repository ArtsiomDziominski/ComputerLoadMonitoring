<UserControl x:Class="ComputerLoadMonitoring.Views.Controls.RamRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="RAM"
                   Style="{StaticResource MetricLabelStyle}" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock Text="{Binding RamUsage, StringFormat={}{0:F1}%}"
                       Foreground="#FFCE93D8"
                       Style="{StaticResource MetricValueStyle}"
                       Margin="0,0,10,0" />
            <TextBlock Foreground="#80FFFFFF"
                       FontSize="13"
                       FontFamily="Consolas">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:F1}/{1:F0} GB">
                        <Binding Path="RamUsed" />
                        <Binding Path="RamTotal" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>
    </Grid>

</UserControl>
