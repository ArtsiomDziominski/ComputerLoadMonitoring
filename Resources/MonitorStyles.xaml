<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:ComputerLoadMonitoring.Helpers">

    <!-- Конвертеры -->
    <h:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    <h:TempToBackgroundConverter x:Key="TempToBackgroundConverter" />
    <h:TempToAlertConverter x:Key="TempToAlertConverter" />

    <!-- Стиль метки (CPU, GPU, RAM) -->
    <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#B0FFFFFF" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Стиль значения (загрузка, температура и т.д.) -->
    <Style x:Key="MetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Стиль корневого Border с анимацией мигания при 90°C+ -->
    <Style x:Key="AlertBorderStyle" TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding MaxTemp, Converter={StaticResource TempToAlertConverter}}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkStoryboard">
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.4"
                                             Duration="0:0:0.5"
                                             AutoReverse="True" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="BlinkStoryboard" />
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
